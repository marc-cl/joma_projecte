<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd"
         version="4.0">
    <display-name>Backend Tienda</display-name>
    <servlet>
        <servlet-name>ServletArticle</servlet-name>
        <servlet-class>com.tienda.servlets.ServletArticle</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ServletArticle</servlet-name>
        <url-pattern>/productes</url-pattern>
        <url-pattern>/api/productes</url-pattern>
        <url-pattern>/api/productes/stock</url-pattern>
    </servlet-mapping>
    <servlet>
        <servlet-name>ServletAuth</servlet-name>
        <servlet-class>com.tienda.servlets.ServletAuth</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ServletAuth</servlet-name>
        <url-pattern>/api/auth/login</url-pattern>
        <url-pattern>/api/auth/logout</url-pattern>
        <url-pattern>/api/auth/session</url-pattern>
    </servlet-mapping>
    <servlet>
        <servlet-name>ServletComanda</servlet-name>
        <servlet-class>com.tienda.servlets.ServletComanda</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ServletComanda</servlet-name>
        <url-pattern>/comandes</url-pattern>
        <url-pattern>/api/comandes</url-pattern>
        <url-pattern>/api/payments/fake</url-pattern>
    </servlet-mapping>
    <servlet>
        <servlet-name>ServletCarret</servlet-name>
        <servlet-class>com.tienda.servlets.ServletCarret</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ServletCarret</servlet-name>
        <url-pattern>/carret</url-pattern>
        <url-pattern>/api/cart</url-pattern>
    </servlet-mapping>
</web-app>